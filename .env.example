# Oracle Database Connection
ORACLE_USER=your_username
ORACLE_PASSWORD=your_password
ORACLE_CONNECTION_STRING=localhost:1521/ORCL
# Format: host:port/service_name
# Or TNS: (DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)))

# Server
PORT=3000

# PDF Output
OUTPUT_DIR=./output
